## Database ##
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<db-name>
DATA_STORAGE=/storage/path

## Multi-Tenancy ##
MULTI_TENANCY=true

## Translations ##
INCLUDE_LANGUAGE=true

## Authentication ##

# Better Auth
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=<secret>

# Basic
BASIC_AUTH_USERNAME=<credentials>
BASIC_AUTH_PASSWORD=<credentials>
# Google OAuth
GOOGLE_CLIENT_ID=<secret>
GOOGLE_CLIENT_SECRET=<secret>
SHOW_GOOGLE_OAUTH=true
# Keycloak Auth
KEYCLOAK_ID=<string>
KEYCLOAK_SECRET=<secret>
KEYCLOAK_ISSUER=<url_with_realm> 
SHOW_KEYCLOAK_OAUTH=true

## Payments ##

# Paypal
PAYPAL_CLIENT_ID=<secret>
PAYPAL_CLIENT_SECRET=<secret>
PAYPAL_LIVE=true # "true" for live payments — defaults to sandbox if not set

# Stripe
STRIPE_CLIENT_ID=<secret>
STRIPE_CLIENT_SECRET=<secret>
STRIPE_WEBHOOK_SECRET=<webhook_secret>

# Paybox
PBX_RANG=<secret>
PBX_IDENTIFIANT=<secret>
PBX_SITE=<secret>
PBX_PAYBOX=<host>
PBX_BACKUP1=<host>
PBX_BACKUP2=<host>
PBX_SECRET=<secret>

# Up2Pay 
UP2PAY_SITE=<secret>
UP2PAY_RANG=<secret>
UP2PAY_IDENTIFIANT=<secret>
UP2PAY_PAYBOX=<host>
UP2PAY_SECRET=<secret>
UP2PAY_LEGACY_FORWARD_URL=

# Hub PISP (BPCE Payment Services)
HUBPISP_TOKEN_URL=<https://auth.hubpisp.example.com/oauth/token>
HUBPISP_API_URL=<https://api.hubpisp.example.com>
HUBPISP_CLIENT_ID=<client_id>
HUBPISP_CLIENT_SECRET=<client_secret>
HUBPISP_CERT_FINGERPRINT=<sha256_fingerprint_of_client_cert>
HUBPISP_BENEFICIARY_NAME=<beneficiary_name>
HUBPISP_IBAN=<iban>
HUBPISP_BIC=<bic>
# mTLS certs: place files at certs/hubpisp/client.crt and certs/hubpisp/private-key.pem


## Notification ##

# Mail
MAIL_HOST=<host>
MAIL_PORT=<port>
MAIL_SECURE=false
MAIL_USER=<credentials>
MAIL_PASSWORD=<credentials>
MAIL_EMAIL=<credentials>

## Public ##

# Goovee
GOOVEE_PUBLIC_HOST=http://localhost:3001
AOS_URL=http://localhost:8080/axelor-erp

# Paypal
GOOVEE_PUBLIC_PAYPAL_CLIENT_ID=<secret>

# Social
GOOVEE_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/login
GOOVEE_PUBLIC_TWITTER_URL=https://x.com/i/flow/login
GOOVEE_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/accounts/login
GOOVEE_PUBLIC_WHATSAPP_URL=https://web.whatsapp.com/

# Mattermost
GOOVEE_PUBLIC_MATTERMOST_HOST=http://localhost:8065
MATTERMOST_TOKEN=<token>

# Mattermost User Creation
CREATE_MATTERMOST_USERS=false

## Web Push ##
# Generate VAPID keys using: npx web-push generate-vapid-keys
GOOVEE_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT must be a mailto: address or an https: URL
VAPID_SUBJECT=mailto:admin@example.com
