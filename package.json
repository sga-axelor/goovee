{
  "name": "@goovee/core",
  "version": "1.7.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development serwist build && next dev",
    "dev:serwist": "concurrently -p none 'serwist build --watch' 'next dev'",
    "build": "next build --no-mangling && serwist build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write --cache \"**/*.{ts,tsx,md,json,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,scss,html}\"",
    "generate": "goovee generate",
    "website:common:dir": "app/[tenant]/[workspace]/(subapps)/website/common/",
    "website:run": "node -r @swc-node/register",
    "website:sass": "sass --no-source-map --quiet $npm_package_scripts_website_common_dir/assets/scss:$npm_package_scripts_website_common_dir/assets/css",
    "website:seed:templates": "npm run website:run $npm_package_scripts_website_common_dir/scripts/seed-templates.ts",
    "website:reset:templates": "npm run website:run $npm_package_scripts_website_common_dir/scripts/reset-templates.ts",
    "website:seed:contents": "npm run website:run $npm_package_scripts_website_common_dir/scripts/seed-contents.ts",
    "website:seed:website": "npm run website:run $npm_package_scripts_website_common_dir/scripts/seed-website.ts",
    "changelogs:validate": "node ./changelogs/validate",
    "changelogs:generate": "node ./changelogs/generate",
    "prepare:release": "node ./prepare-release.js",
    "analyze": "next experimental-analyze"
  },
